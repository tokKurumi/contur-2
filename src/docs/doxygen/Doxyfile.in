#-----------------------------------------------------------------------
# Contur 2 base Doxygen config
# Generated by CMake into build/<preset>/Doxyfile.docs
#
# This file defines stable defaults and includes an external override file:
#   @CONTUR2_DOXYFILE_OVERRIDE@
# Put project-specific customizations in docs/doxygen/Doxyfile.override.in.
#-----------------------------------------------------------------------

PROJECT_NAME           = "Contur 2"
PROJECT_BRIEF          = "Educational OS kernel simulator"
PROJECT_NUMBER         =

OUTPUT_DIRECTORY       = @CMAKE_CURRENT_BINARY_DIR@
CREATE_SUBDIRS         = YES
OUTPUT_LANGUAGE        = English
FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = @CMAKE_CURRENT_SOURCE_DIR@

MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 2

INPUT                  = @CMAKE_CURRENT_SOURCE_DIR@/include \
                         @CMAKE_CURRENT_SOURCE_DIR@/app \
                         @CMAKE_CURRENT_SOURCE_DIR@/docs/doxygen/mainpage.md \
                         @CMAKE_CURRENT_SOURCE_DIR@/docs/doxygen/getting_started.md
FILE_PATTERNS          = *.h *.hpp *.hh *.hxx *.cpp *.cc *.cxx *.md
RECURSIVE              = YES
EXCLUDE                = @CMAKE_CURRENT_SOURCE_DIR@/build
EXCLUDE_PATTERNS       = */build/* */_deps/*

USE_MDFILE_AS_MAINPAGE = @CMAKE_CURRENT_SOURCE_DIR@/docs/doxygen/mainpage.md

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

SOURCE_BROWSER         = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO

# External override file. Values defined there override this base config.
@INCLUDE               = @CONTUR2_DOXYFILE_OVERRIDE@
