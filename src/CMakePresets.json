{
    "version": 6,
    "configurePresets": [
        {
            "name": "base-debug",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CONTUR2_ENABLE_TRACING": "ON"
            }
        },
        {
            "name": "base-release",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "base-tsan-debug",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/tsan-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CONTUR2_ENABLE_TRACING": "ON",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -fsanitize=thread",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=thread"
            }
        },
        {
            "name": "base-tsan-release",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/tsan-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -fsanitize=thread",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=thread"
            }
        },

        {
            "name": "debug",
            "displayName": "Debug (Clang)",
            "inherits": "base-debug",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -fsanitize=address,undefined",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined"
            },
            "condition": {
                "type": "notEquals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "release",
            "displayName": "Release (Clang)",
            "inherits": "base-release",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic"
            },
            "condition": {
                "type": "notEquals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "gcc-debug",
            "displayName": "Debug (GCC)",
            "inherits": "base-debug",
            "binaryDir": "${sourceDir}/build/gcc-debug",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -fsanitize=address,undefined",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined"
            },
            "condition": {
                "type": "notEquals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "gcc-release",
            "displayName": "Release (GCC)",
            "inherits": "base-release",
            "binaryDir": "${sourceDir}/build/gcc-release",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -fsanitize=address,undefined",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined"
            },
            "condition": {
                "type": "notEquals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },

        {
            "name": "win-debug",
            "displayName": "Debug (clang++)",
            "inherits": "base-debug",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic",
                "CMAKE_EXE_LINKER_FLAGS": ""
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "win-release",
            "displayName": "Release (clang++)",
            "inherits": "base-release",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },

        {
            "name": "tsan-debug",
            "displayName": "TSAN Debug (Clang)",
            "inherits": "base-tsan-debug",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            },
            "condition": {
                "type": "notEquals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "tsan-release",
            "displayName": "TSAN Release (Clang)",
            "inherits": "base-tsan-release",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            },
            "condition": {
                "type": "notEquals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "tsan-gcc-debug",
            "displayName": "TSAN Debug (GCC)",
            "inherits": "base-tsan-debug",
            "binaryDir": "${sourceDir}/build/tsan-gcc-debug",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++"
            },
            "condition": {
                "type": "notEquals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "tsan-gcc-release",
            "displayName": "TSAN Release (GCC)",
            "inherits": "base-tsan-release",
            "binaryDir": "${sourceDir}/build/tsan-gcc-release",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++"
            },
            "condition": {
                "type": "notEquals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "tsan-win-debug",
            "displayName": "TSAN Debug (clang++)",
            "inherits": "base-tsan-debug",
            "binaryDir": "${sourceDir}/build/tsan-win-debug",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "tsan-win-release",
            "displayName": "TSAN Release (clang++)",
            "inherits": "base-tsan-release",
            "binaryDir": "${sourceDir}/build/tsan-win-release",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        }
    ],

    "buildPresets": [
        { "name": "debug", "configurePreset": "debug" },
        { "name": "release", "configurePreset": "release" },
        { "name": "tsan-debug", "configurePreset": "tsan-debug" },
        { "name": "tsan-release", "configurePreset": "tsan-release" },
        { "name": "tsan-gcc-debug", "configurePreset": "tsan-gcc-debug" },
        { "name": "tsan-gcc-release", "configurePreset": "tsan-gcc-release" },
        { "name": "tsan-win-debug", "configurePreset": "tsan-win-debug" },
        { "name": "tsan-win-release", "configurePreset": "tsan-win-release" },
        { "name": "gcc-debug", "configurePreset": "gcc-debug" },
        { "name": "gcc-release", "configurePreset": "gcc-release" },
        { "name": "win-debug", "configurePreset": "win-debug" },
        { "name": "win-release", "configurePreset": "win-release" }
    ],

    "testPresets": [
        {
            "name": "debug",
            "configurePreset": "debug",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "release",
            "configurePreset": "release",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "tsan-debug",
            "configurePreset": "tsan-debug",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "tsan-release",
            "configurePreset": "tsan-release",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "tsan-gcc-debug",
            "configurePreset": "tsan-gcc-debug",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "tsan-gcc-release",
            "configurePreset": "tsan-gcc-release",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "tsan-win-debug",
            "configurePreset": "tsan-win-debug",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "tsan-win-release",
            "configurePreset": "tsan-win-release",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "gcc-debug",
            "configurePreset": "gcc-debug",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "gcc-release",
            "configurePreset": "gcc-release",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "win-debug",
            "configurePreset": "win-debug",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "win-release",
            "configurePreset": "win-release",
            "output": { "outputOnFailure": true }
        }
    ]
}