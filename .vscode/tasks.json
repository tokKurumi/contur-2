{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build contur2 (Debug)",
            "type": "shell",
            "command": "bash",
            "args": [
                "${workspaceFolder}/src/build.sh",
                "debug",
                "${workspaceFolder}/src"
            ],
            "windows": {
                "command": "powershell",
                "args": [
                    "-ExecutionPolicy", "Bypass",
                    "-File", "${workspaceFolder}/src/build.ps1",
                    "-Preset", "debug",
                    "-SourceDir", "${workspaceFolder}/src"
                ]
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build contur2 (Release)",
            "type": "shell",
            "command": "bash",
            "args": [
                "${workspaceFolder}/src/build.sh",
                "release",
                "${workspaceFolder}/src"
            ],
            "windows": {
                "command": "powershell",
                "args": [
                    "-ExecutionPolicy", "Bypass",
                    "-File", "${workspaceFolder}/src/build.ps1",
                    "-Preset", "release",
                    "-SourceDir", "${workspaceFolder}/src"
                ]
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "ctest",
            "args": ["--preset", "debug", "--output-on-failure"],
            "windows": {
                "args": ["--preset", "win-debug", "--output-on-failure"]
            },
            "options": {
                "cwd": "${workspaceFolder}/src"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Clear build artifacts",
            "type": "shell",
            "command": "rm -rf ${workspaceFolder}/src/build/*",
            "windows": {
                "command": "powershell",
                "args": [
                    "-Command",
                    "Remove-Item -Recurse -Force '${workspaceFolder}/src/build/*' -ErrorAction SilentlyContinue"
                ]
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Format Code (All Files)",
            "type": "shell",
            "command": "bash",
            "args": [
                "${workspaceFolder}/misc/format.sh"
            ],
            "windows": {
                "command": "powershell",
                "args": [
                    "-Command",
                    "Get-ChildItem -Path '${workspaceFolder}/src' -Recurse -Include *.cpp,*.h | Where-Object { $_.FullName -notmatch 'build' } | ForEach-Object { clang-format -i $_.FullName; Write-Host \"  Formatted: $($_.Name)\" }"
                ]
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Format Code (Current File)",
            "type": "shell",
            "command": "clang-format",
            "args": [
                "-i",
                "${file}"
            ],
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
